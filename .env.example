APP_NAME=LaborTrackIQ API
APP_ENVIRONMENT=development
DATABASE_URL=sqlite:///./labortrackiq.db
API_PREFIX=/api
SECRET_KEY=change-me-for-production
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_SCOPES=com.intuit.quickbooks.accounting
ALLOW_DEMO_BOOTSTRAP=true
MAX_REQUEST_BYTES=1048576
AUTH_RATE_LIMIT=20
AUTH_RATE_WINDOW_SECONDS=60
CLOCK_RATE_LIMIT=60
CLOCK_RATE_WINDOW_SECONDS=60
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
