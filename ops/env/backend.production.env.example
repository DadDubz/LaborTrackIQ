APP_NAME=LaborTrackIQ API
APP_ENVIRONMENT=production
API_PREFIX=/api
DATABASE_URL=postgresql+psycopg://labortrackiq:change-me@db-host:5432/labortrackiq
SECRET_KEY=replace-with-long-random-secret
ALLOW_DEMO_BOOTSTRAP=false
MAX_REQUEST_BYTES=1048576
AUTH_RATE_LIMIT=20
AUTH_RATE_WINDOW_SECONDS=60
CLOCK_RATE_LIMIT=60
CLOCK_RATE_WINDOW_SECONDS=60
CLOCK_EMPLOYEE_RATE_LIMIT=20
CLOCK_EMPLOYEE_RATE_WINDOW_SECONDS=60
TRUST_PROXY_HEADERS=true
CORS_ORIGINS=https://app.example.com
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=https://api.example.com/api/integrations/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=production
QUICKBOOKS_SCOPES=com.intuit.quickbooks.accounting
